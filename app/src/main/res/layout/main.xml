<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@color/adguard_bg"
android:fillViewport="true">
<LinearLayout
android:orientation="vertical"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:padding="20dp">

<TextView
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:text="卡卡广告过滤器"
android:textColor="@color/adguard_text"
android:textSize="24sp"
android:textStyle="bold"
android:gravity="center"
android:layout_marginTop="12dp"
android:layout_marginBottom="24dp"/>

<Button
android:id="@+id/control"
android:layout_width="match_parent"
android:layout_height="64dp"
android:text="@string/control_enable"
android:textSize="18sp"
android:textColor="@color/adguard_text"
android:backgroundTint="@color/adguard_green"/>

<TextView
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:text="QQ: 463399295"
android:textColor="@color/adguard_text_secondary"
android:textSize="13sp"
android:gravity="center"
android:layout_marginTop="20dp"/>

<TextView
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:text="抖音: 152688026"
android:textColor="@color/adguard_text_secondary"
android:textSize="13sp"
android:gravity="center"
android:layout_marginTop="4dp"
android:layout_marginBottom="28dp"/>

<View
android:layout_width="match_parent"
android:layout_height="1dp"
android:background="@color/adguard_card_bg"
android:layout_marginBottom="16dp"/>

<TextView
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:text="高级设置"
android:textColor="@color/adguard_text_secondary"
android:textSize="13sp"
android:layout_marginBottom="8dp"/>

<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_socks_addr"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:hint="@string/socks_addr">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/socks_addr"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="text"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_socks_udp_addr"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/socks_udp_addr">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/socks_udp_addr"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="text"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_socks_port"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/socks_port">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/socks_port"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="number"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_socks_user"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/socks_user">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/socks_user"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="text"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_socks_pass"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/socks_pass"
app:endIconMode="password_toggle">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/socks_pass"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:inputType="textPassword"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_dns_ipv4"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/dns_ipv4">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/dns_ipv4"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:digits="0123456789."
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<com.google.android.material.textfield.TextInputLayout
android:id="@+id/til_dns_ipv6"
style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:hint="@string/dns_ipv6">
<com.google.android.material.textfield.TextInputEditText
android:id="@+id/dns_ipv6"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:digits="0123456789abcdef:"
android:maxLines="1"/>
</com.google.android.material.textfield.TextInputLayout>
<LinearLayout
android:orientation="horizontal"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp">
<CheckBox
android:id="@+id/remote_dns"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/remote_dns"/>
<CheckBox
android:id="@+id/udp_in_tcp"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/udp_in_tcp"/>
</LinearLayout>
<LinearLayout
android:orientation="horizontal"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:gravity="center_vertical">
<CheckBox
android:id="@+id/ipv4"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/ipv4"/>
<CheckBox
android:id="@+id/ipv6"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/ipv6"/>
<CheckBox
android:id="@+id/global"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/global"/>
<Button
android:id="@+id/apps"
style="?attr/materialButtonOutlinedStyle"
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:text="@string/apps"/>
</LinearLayout>
<Button
android:id="@+id/save"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginTop="8dp"
android:text="@string/save"/>
</LinearLayout>
</ScrollView>
